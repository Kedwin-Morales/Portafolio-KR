---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../lib/data';
---

<section id="inicio" class="min-h-screen flex items-center pt-20 bg-theme">
  <Container>
    <div class="flex flex-col md:flex-row items-center gap-12 hero-content">
      <div class="flex-1 text-center md:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-texto mb-4">
          {siteConfig.name}<span class="text-primary">.</span>
        </h1>
        <h2 class="text-xl md:text-2xl text-secondary mb-6 font-mono">
          {siteConfig.title}
        </h2>
        <p class="text-lg text-secondary mb-8 max-w-2xl">
          Desarrollador Full Stack especializado en .NET, C#, Blazor y Entity Framework. 5+ años
          construyendo soluciones escalables con buenas prácticas de arquitectura.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <Button href="#contacto" variant="primary">Contacto</Button>
          <Button href="/(CV)KedwinMorales.pdf" variant="outline">Descargar CV</Button>
        </div>

        <div class="flex items-center gap-4 mt-8 justify-center md:justify-start">
          <a
            href={siteConfig.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-texto hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.799 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.776.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.399 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.625-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.496.694.824.576 4.765-1.589 8.199-6.087 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href={siteConfig.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-texto hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.963 0-1.718-.758-1.718-1.697s.755-1.697 1.718-1.697 1.718.758 1.718 1.697-.755 1.697-1.718 1.697zm13.5 12.268h-3v-5.5c0-1.327-.026-3.037-1.852-3.037-1.853 0-2.136 1.446-2.136 2.944v5.592h-3v-11h2.881v1.636h.039c.2-.395.717-1.036 2.265-1.036 2.23 0 2.715 1.498 2.715 3.494v7.282zm-4-6.732c0 1.2-.022 2.58-.022 3.58 0 .998.019 1.996.019 3.58h-2.881v-11h2.762v1.626h.035c.286-.547 1.004-1.155 2.283-1.155 2.154 0 2.92 1.443 2.92 3.445v7.19z"
              ></path>
            </svg>
          </a>
          <a
            href={`mailto:${siteConfig.email}`}
            class="text-texto hover:text-primary transition-colors"
            aria-label="Email"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              >
              </path>
            </svg>
          </a>
        </div>
      </div>

      <div class="flex-1 flex justify-center">
        <div class="relative w-64 h-64 md:w-80 md:h-80">
          <div class="absolute inset-0 rounded-full bg-primary/20 animate-pulse"></div>
          <img
            src="/unidad-medida.jpeg"
            alt="Foto de perfil"
            class="relative w-full h-full rounded-full object-cover border-4 border-primary/30"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  import { animate, inView } from '@motionone/dom';

  const heroContent = document.querySelector('.hero-content');

  if (heroContent) {
    animate(
      heroContent,
      {
        opacity: [0, 1],
        transform: ['translateY(30px)', 'translateY(0px)'],
      },
      {
        duration: 0.8,
        easing: 'ease-out',
      }
    );
  }
</script>
