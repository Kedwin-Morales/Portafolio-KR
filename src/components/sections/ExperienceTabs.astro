---
import Container from '../ui/Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import { experience } from '../../lib/data';
---

<section id="experiencia" class="bg-theme reveal-on-scroll">
  <Container>
    <SectionTitle>Experiencia</SectionTitle>

    <div class="experience-tabs" data-experience-count={experience.length}>
      <div class="flex flex-col md:flex-row gap-8">
        <div class="md:w-1/3">
          <div class="flex flex-col space-y-2" role="tablist" aria-label="Lista de experiencias">
            {
              experience.map((exp, index) => (
                <button
                  class={`tab-button text-left px-4 py-3 rounded-lg font-mono text-sm transition-all ${index === 0 ? 'bg-primary/10 text-primary font-semibold' : 'text-secondary hover:text-texto hover:bg-bordes/50'}`}
                  data-index={index}
                  role="tab"
                  aria-selected={index === 0}
                  aria-controls={`panel-${exp.id}`}
                >
                  {exp.company}
                </button>
              ))
            }
          </div>
        </div>

        <div class="md:w-2/3">
          {
            experience.map((exp, index) => (
              <div
                id={`panel-${exp.id}`}
                class={`tab-panel ${index === 0 ? '' : 'hidden'}`}
                role="tabpanel"
                aria-labelledby={`tab-${exp.id}`}
              >
                <h3 class="text-2xl font-bold text-texto mb-2">{exp.position}</h3>
                <p class="text-secondary font-mono mb-4">
                  {exp.company} • {exp.period}
                </p>
                <p class="text-secondary mb-6">{exp.description}</p>

                <ul class="space-y-3 mb-6">
                  {exp.achievements.map((achievement) => (
                    <li class="flex items-start">
                      <span class="text-primary mr-2">▸</span>
                      <span class="text-secondary">{achievement}</span>
                    </li>
                  ))}
                </ul>

                <div class="flex flex-wrap gap-2">
                  {exp.technologies.map((tech) => (
                    <span class="px-3 py-1 text-sm font-mono bg-bordes/50 text-texto rounded-full">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const index = button.getAttribute('data-index');

      tabButtons.forEach((btn) => {
        btn.classList.remove('bg-primary/10', 'text-primary', 'font-semibold');
        btn.classList.add('text-secondary');
      });

      button.classList.add('bg-primary/10', 'text-primary', 'font-semibold');
      button.classList.remove('text-secondary');

      tabPanels.forEach((panel) => panel.classList.add('hidden'));
      const targetPanel = document.querySelector(
        `[data-experience-count] .tab-panel:nth-child(${Number(index) + 1})`
      );
      targetPanel?.classList.remove('hidden');
    });
  });
</script>
