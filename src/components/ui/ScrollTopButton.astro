---
import ChevronUp from '../icons/ChevronUp.astro';
---

<button
  id="scroll-top"
  class="fixed bottom-8 right-8 p-3 rounded-full bg-(--primary) text-white shadow-lg opacity-0 invisible transition-all duration-300 hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary"
  aria-label="Volver arriba"
>
  <ChevronUp class="w-5 h-5" />
</button>

<script>
  const scrollButton = document.getElementById('scroll-top');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      scrollButton?.classList.remove('opacity-0', 'invisible');
      scrollButton?.classList.add('opacity-100', 'visible');
    } else {
      scrollButton?.classList.add('opacity-0', 'invisible');
      scrollButton?.classList.remove('opacity-100', 'visible');
    }
  });

  scrollButton?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
